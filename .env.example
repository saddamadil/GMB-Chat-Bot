# ============================================================
#  GMB AI Agent v2 — Environment Variables
#  Copy to .env and fill in your real values
#  NEVER commit .env to git!
# ============================================================

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=1063749866199-apie30oppq4bj95n9jjbr8dchmpvpnc6.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_NEW_REGENERATED_SECRET_HERE
GOOGLE_REDIRECT_URI=https://yourdomain.com/auth/callback

# ── Anthropic Claude API ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── PostgreSQL Database ───────────────────────────────────────
# Local Docker:   postgresql://gmbuser:gmbpass@localhost:5432/gmbagent
# Railway/Render: provided automatically
DATABASE_URL=postgresql://gmbuser:gmbpass@localhost:5432/gmbagent

# ── Webhook Security ──────────────────────────────────────────
WEBHOOK_SECRET=generate-random-string-here

# ── Session ───────────────────────────────────────────────────
SESSION_SECRET=another-random-long-string-here

# ── App ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# ── Your GMB IDs (find after /auth/google) ───────────────────
GMB_ACCOUNT_ID=
GMB_LOCATION_ID=

# ── Restaurant Info ───────────────────────────────────────────
RESTAURANT_NAME=Spice Garden Restaurant
RESTAURANT_ADDRESS=SG Highway, Ahmedabad, Gujarat
RESTAURANT_PHONE=+91 98765 43210
RESTAURANT_HOURS=Mon-Sun 11:00 AM - 11:00 PM
