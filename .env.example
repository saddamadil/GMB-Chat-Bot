# ============================================================
#  GMB AI Agent v2 — Environment Variables (local-development)
#  Copy this file to .env and fill in your real values
#  NEVER commit .env to git!
# ============================================================

# ── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=1063749866199-apie30oppq4bj95n9jjbr8dchmpvpnc6.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_NEW_REGENERATED_SECRET_HERE
# For local development use this redirect URI and also add it in Google Cloud OAuth client
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/callback

# ── Anthropic Claude API ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── PostgreSQL Database ───────────────────────────────────────
# Local Docker example: postgresql://gmbuser:gmbpass@localhost:5432/gmbagent
# If you use a hosted DB (Railway/Render) they will provide the DATABASE_URL
DATABASE_URL=postgresql://gmbuser:gmbpass@localhost:5432/gmbagent

# ── Webhook Security ──────────────────────────────────────────
WEBHOOK_SECRET=generate-a-random-string-here

# ── Session ───────────────────────────────────────────────────
SESSION_SECRET=another-random-long-string-here

# ── App ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# For local testing use frontend URL pointing to the same host/port
FRONTEND_URL=http://localhost:3001

# ── Your GMB IDs (optional — can be discovered after /auth/google) ─
GMB_ACCOUNT_ID=
GMB_LOCATION_ID=

# ── Restaurant Info ───────────────────────────────────────────
RESTAURANT_NAME=Spice Garden Restaurant
RESTAURANT_ADDRESS=SG Highway, Ahmedabad, Gujarat
RESTAURANT_PHONE=+91 98765 43210
RESTAURANT_HOURS=Mon-Sun 11:00 AM - 11:00 PM

# Notes:
# - After copying this file to .env and filling values, DO NOT commit the .env file.
# - Regenerate your Google client secret immediately if it has been exposed.
# - Update GOOGLE_REDIRECT_URI in Google Cloud Console to match this value for local testing.